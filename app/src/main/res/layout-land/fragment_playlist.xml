<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/appBackground">

    <!-- Header / portada -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/portada" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/appImageOverlay" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:padding="24dp"
            android:text="Mi Playlist"
            android:textColor="?attr/appTextOnImage"
            android:textSize="32sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Barra de controles -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/appSurface"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Todas las canciones"
            android:textColor="?attr/appTextSecondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSort"
            style="@style/AppSortButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Ordenar Z-A"
            android:textColor="?attr/appAccent"
            app:iconTint="?attr/appAccent"
            app:rippleColor="?attr/appAccent" />
    </RelativeLayout>

    <!-- Línea divisoria -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/appDivider" />

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSongs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/appBackground"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="12dp" />

</LinearLayout>